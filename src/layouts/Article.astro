---
import Base from './Base.astro';
import CtaBand from '../components/CtaBand.astro';

const { frontmatter } = Astro.props;
const site = 'https://truckercopilot.com';
const path = Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '').replace(/\/$/, '');
const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: frontmatter.title,
    description: frontmatter.description,
    author: { '@type': 'Organization', name: 'Trucker Copilot' },
    publisher: { '@type': 'Organization', name: 'Trucker Copilot', url: site },
    mainEntityOfPage: site + path,
    datePublished: frontmatter.date || '2026-07-21',
    dateModified: frontmatter.updated || frontmatter.date || '2026-07-21'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: site + '/' },
      { '@type': 'ListItem', position: 2, name: 'Resources', item: site + '/resources' },
      { '@type': 'ListItem', position: 3, name: frontmatter.title, item: site + path }
    ]
  }
];
---
<Base title={frontmatter.seoTitle || frontmatter.title + ' | Trucker Copilot'} description={frontmatter.description} schema={schema}>
  <div class="container container--narrow">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a> › <a href="/resources">Resources</a> › <span>{frontmatter.title}</span>
    </nav>
    <article class="prose section" style="padding-top:1.5rem;">
      <h1>{frontmatter.title}</h1>
      <p class="article-meta">Trucker Copilot Resources</p>
      <slot />
    </article>
  </div>
  <CtaBand
    headline="From delivered to funded."
    body="Capture the load, send the proof, follow the status, and stay connected from the road."
    primaryLabel="Get Trucker Copilot"
    primaryHref="/download"
    secondaryLabel="Explore the Funding Network"
    secondaryHref="/funding-network"
  />
</Base>
