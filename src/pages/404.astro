---
import Base from '../layouts/Base.astro';
---
<Base
  title="Page Not Found | Trucker Copilot"
  description="That page is not here. Head back to Trucker Copilot to capture load documents, follow funding status, and connect with finance companies."
>
  <section class="hero">
    <div class="container center" style="padding-bottom:3rem;">
      <span class="eyebrow">404</span>
      <h1>That page took a wrong exit.</h1>
      <p class="lead" style="color:var(--text-muted); max-width:38em; margin-left:auto; margin-right:auto;">
        The page you are looking for is not here. The money you are looking for probably is.
      </p>
      <div class="hero__actions" style="justify-content:center;">
        <a class="btn btn--primary btn--lg" href="/">Back to Home</a>
        <a class="btn btn--ghost btn--lg" href="/resources">Browse Resources</a>
        <a class="btn btn--ghost btn--lg" href="/download">Get the App</a>
      </div>
    </div>
  </section>
</Base>
