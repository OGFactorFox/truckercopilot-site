---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';

const steps = [
  { t: 'Create or receive the load', d: 'Load information enters Trucker Copilot through the driver, dispatcher, fleet, or a connected transportation system. The people responsible for the load work from the same transaction instead of rebuilding it across texts, email, and paper.' },
  { t: 'Capture activity as it happens', d: 'Record pickup, delivery, confirmations, load details, and supporting documents from the road. Trucker Copilot keeps the operational record connected to the financial transaction.' },
  { t: 'Submit the completed load', d: 'Upload the invoice, rate confirmation, bill of lading, proof of delivery, and any required supporting documents. The information moves into the FactorEvo infrastructure without manual reentry.' },
  { t: 'Turn activity into Signals', d: 'Documents, identity, authority, delivery events, broker credit information, communication, and other verified activity become Signals. Those Signals give the finance provider more context around what happened and what requires attention.' },
  { t: 'Follow the funding decision', d: 'See the transaction status as your selected finance provider reviews eligibility, verifies the evidence, and makes the funding decision. Timing and approval remain subject to provider requirements and terms.' },
  { t: 'Keep the operating record', d: 'The load does not vanish after submission. Trucker Copilot preserves the connected activity so drivers, dispatchers, carriers, and authorized finance teams can work from a shared record.' }
];

const stages = [
  { icon: '🚛', label: 'Run the load' },
  { icon: '📸', label: 'Capture the proof' },
  { icon: '📡', label: 'Create the Signals' },
  { icon: '🏦', label: 'Provider review' },
  { icon: '💵', label: 'Funding decision' }
];
---
<Base
  title="How Trucker Copilot Works | Load Documents to Funding"
  description="See how Trucker Copilot connects load activity, delivery documents, Signals, and transportation finance companies from the cab to the funding decision."
>
  <section class="hero" style="padding-bottom:2.5rem;">
    <div class="container hero__grid">
      <div>
        <span class="eyebrow">How It Works</span>
        <h1>One connected path from the load to the money.</h1>
        <p class="lead" style="color:var(--text-muted); max-width:34em;">
          Trucker Copilot reduces the gap between completing the work and getting the transaction
          into the hands of the people who can fund it. Every step creates clearer evidence, better
          visibility, and fewer reasons for the process to stop.
        </p>
      </div>
      <div style="display:flex; justify-content:center;">
        <div class="phone-frame phone-cycler" aria-label="Trucker Copilot app screens">
          <img src="/img/app/create-invoice.jpg" alt="Creating an invoice for a load in Trucker Copilot" />
          <img src="/img/app/route-map.jpg" alt="Route map with fuel prices in Trucker Copilot" />
          <img src="/img/app/dashboard.jpg" alt="Trucker Copilot dashboard with broker credit check" />
        </div>
      </div>
    </div>
  </section>

  <!-- Animated journey pipeline -->
  <section class="section" style="padding-top:1.5rem; padding-bottom:2rem;">
    <div class="container">
      <div class="pipeline" role="img" aria-label="The journey from running the load to the funding decision">
        <div class="pipeline__track"><div class="pipeline__comet"></div></div>
        {stages.map((s, i) => (
          <div class="pipeline__node" style={`--i:${i}`}>
            <div class="pipeline__dot">{s.icon}</div>
            <span>{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:1rem;">
    <div class="container">
      <div class="steps steps--animated">
        {steps.map((s) => (
          <div class="step reveal">
            <div class="step__num"></div>
            <div>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    headline="The work already happened. The evidence should move just as fast."
    primaryLabel="Join Trucker Copilot"
    primaryHref="/download"
    secondaryLabel="Explore the Features"
    secondaryHref="/features"
  />
</Base>

<style>
  /* Phone screenshot crossfade cycler */
  .phone-cycler { position: relative; }
  .phone-cycler img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    animation: cycler 12s infinite;
  }
  .phone-cycler img:nth-child(1) { animation-delay: 0s; position: relative; }
  .phone-cycler img:nth-child(2) { animation-delay: 4s; }
  .phone-cycler img:nth-child(3) { animation-delay: 8s; }
  @keyframes cycler {
    0% { opacity: 0; }
    4% { opacity: 1; }
    33.33% { opacity: 1; }
    41% { opacity: 0; }
    100% { opacity: 0; }
  }

  /* Journey pipeline */
  .pipeline {
    position: relative;
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 1.5rem 0.5rem 0.5rem;
  }
  .pipeline__track {
    position: absolute;
    left: 6%;
    right: 6%;
    top: calc(1.5rem + 28px);
    height: 4px;
    border-radius: 4px;
    background: var(--border);
    overflow: hidden;
  }
  .pipeline__comet {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 30%;
    border-radius: 4px;
    background: linear-gradient(90deg, transparent, var(--primary));
    animation: comet 6s linear infinite;
  }
  @keyframes comet {
    0% { left: -35%; }
    100% { left: 105%; }
  }
  .pipeline__node {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    flex: 1;
    min-width: 0;
  }
  .pipeline__dot {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--bg-raised);
    border: 2px solid var(--border-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    animation: nodePulse 6s infinite;
    animation-delay: calc(var(--i) * 1.2s);
  }
  @keyframes nodePulse {
    0%, 100% { border-color: var(--border-strong); box-shadow: none; transform: scale(1); }
    10% { border-color: var(--primary); box-shadow: 0 0 0 8px color-mix(in srgb, var(--primary) 18%, transparent); transform: scale(1.08); }
    24% { border-color: var(--border-strong); box-shadow: none; transform: scale(1); }
  }
  .pipeline__node span {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text-muted);
  }
  @media (max-width: 720px) {
    .pipeline { flex-wrap: wrap; row-gap: 1.4rem; }
    .pipeline__node { flex: 1 1 30%; }
    .pipeline__track { display: none; }
  }

  /* Scroll reveal steps */
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible { opacity: 1; transform: none; }

  @media (prefers-reduced-motion: reduce) {
    .phone-cycler img { animation: none; opacity: 0; }
    .phone-cycler img:nth-child(1) { opacity: 1; }
    .pipeline__comet, .pipeline__dot { animation: none; }
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script is:inline>
  (function () {
    var els = document.querySelectorAll('.reveal');
    if (!('IntersectionObserver' in window)) {
      els.forEach(function (el) { el.classList.add('visible'); });
      return;
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); }
      });
    }, { threshold: 0.15 });
    els.forEach(function (el) { io.observe(el); });
  })();
</script>
